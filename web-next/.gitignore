# dependencies
/node_modules

# next.js
/.next/
/out/

# testing / coverage
/coverage

# production
/build

# misc
.DS_Store
*.pem

# env（秘密・公開値問わずコミットしない。テンプレートの .env.example のみ追跡）
.env*
!.env.example

# 著作権保護 PROM 質問文のローカル専用オーバーレイ（一般公開しない）。
# テンプレートの prom-restricted.example.json のみ追跡する。詳細は THIRD_PARTY_NOTICES.md §2。
/public/*.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# ルート .gitignore の Python 向け `lib/` 無視を上書きし、Next.js の lib/ を追跡する
!/lib/
!/lib/**
