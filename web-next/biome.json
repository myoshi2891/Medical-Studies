{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!.next",
      "!node_modules",
      "!next-env.d.ts",
      "!app/globals.css",
      "!app/prom-checker/prom-checker.css",
      "!app/blocks/cervical-plexus-block/cervical-plexus-block.css",
      "!app/blocks/occipital-nerve-block/occipital-nerve-block.css",
      "!app/blocks/stellate-ganglion-block/stellate-ganglion-block.css",
      "!app/anatomy/anatomy.css",
      "!app/headaches/cervicogenic-headache/cervicogenic-headache.css",
      "!app/headaches/medication-overuse-headache/medication-overuse-headache.css",
      "!app/headaches/migraine/migraine.css",
      "!app/headaches/tension-type-headache/tension-type-headache.css",
      "!app/therapies/nutrition-and-supplements/nutrition-and-supplements.css",
      "!app/therapies/physical-therapy-for-headache/physical-therapy-for-headache.css",
      "!app/therapies/psychological-behavioral-therapy/psychological-behavioral-therapy.css",
      "!app/prom/headache-diary/headache-diary.css",
      "!app/prom/headache-impact-test/headache-impact-test.css",
      "!app/prom/migraine-disability-assessment/migraine-disability-assessment.css",
      "!app/prom/migraine-specific-quality-of-life/migraine-specific-quality-of-life.css",
      "!app/prom/numerical-rating-scale-visual-analogue-scale/numerical-rating-scale-visual-analogue-scale.css",
      "!app/prom/patient-global-impression-of-change/patient-global-impression-of-change.css",
      "!app/therapies/headache-acupoints-trigger-points/headache-acupoints-trigger-points.css",
      "!app/therapies/trigger-points-and-headache/trigger-points-and-headache.css",
      "!app/treatment/acute-treatment-of-headache/acute-treatment-of-headache.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error",
        "noDoubleEquals": "error",
        "noEmptyBlockStatements": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
